# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# …but the placeholder example IS tracked (no real secrets).
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local imported roster (dev bypass)
.dev-data/

# Treigning Lab importer — scraped data, outputs, and browser session (cookies!)
tools/treigning-import/raw-backup/
tools/treigning-import/out/
tools/treigning-import/.session/
.claude/
