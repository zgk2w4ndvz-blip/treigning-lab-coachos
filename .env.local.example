# ---- Clerk ----------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxx

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ---- Supabase -------------------------------------------------------------
# Use the NEW API key format (Supabase dashboard → Project Settings → API Keys).
#   • Publishable key  → sb_publishable_...  (safe for the browser; the anon role)
#   • Secret key       → sb_secret_...       (server only; never expose / commit)
# The legacy JWT keys (eyJ...) are deprecated and may be disabled on the project —
# a disabled legacy service_role key returns HTTP 401 "Invalid API key".
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Direct Postgres connection string — used ONLY by scripts/setup-supabase.sh to
# apply migrations (not read by the app). Supabase dashboard → Project Settings
# → Database → Connection string → URI.
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.xxxx.supabase.co:5432/postgres

# ---- Gmail source adapter (message inbox) ----------------------------------
# Either a short-lived access token, OR client+secret+refresh for auto-exchange.
# GMAIL_ACCESS_TOKEN=ya29....
# GMAIL_CLIENT_ID=xxxx.apps.googleusercontent.com
# GMAIL_CLIENT_SECRET=xxxx
# GMAIL_REFRESH_TOKEN=xxxx
# GMAIL_QUERY=newer_than:7d -in:chats   # optional Gmail search
# Continuous sync (Vercel Cron → /api/cron/gmail-sync, hourly):
# CRON_SECRET=long-random-string         # Vercel sends it as Authorization: Bearer
# CRON_COACH_ID=00000000-...             # profiles.id the cron ingests as

# ---- Local iMessage bridge ingest endpoints (/api/ingest) ------------------
# Bearer-authenticated machine endpoints used by the local Mac bridge.
# v1 single coach:
# BRIDGE_TOKEN=long-random-string        # sent as `Authorization: Bearer <token>`
# BRIDGE_COACH_ID=00000000-...           # profiles.id the bridge ingests as
# Multi-coach (overrides the single pair above) — JSON map of token → coach id:
# BRIDGE_TOKENS={"tokenA":"<coachProfileIdA>","tokenB":"<coachProfileIdB>"}

# ---- Treigning Lab importer (tools/treigning-import) -----------------------
# Used ONLY by the one-off migration scripts, never by the app.
TREIGNING_TEAM_URL=https://treigninglab.app/app/.../athletes/athlete-list
COACH_ID=00000000-0000-0000-0000-000000000000   # profiles.id that owns imported clients
# IMPORT_MAX_ATHLETES=3   # optional: cap for a first test run
# IMPORT_DELAY_MS=1500    # optional: politeness delay between athlete pages

# ---- Dev only -------------------------------------------------------------
# Set true to bypass Clerk + Supabase and serve in-memory mock data, so you
# can click through the app with no real credentials. Hard-disabled in prod
# builds (NODE_ENV=production). Leave false/unset for normal development.
NEXT_PUBLIC_DEV_AUTH_BYPASS=false

# ---- Anthropic AI integration (message extraction; ships DISABLED) ----------
# Secret — set in Vercel env / .env.local only. NEVER commit a real key.
ANTHROPIC_API_KEY=
# Global kill switch. Leave false to keep 100% deterministic (regex) extraction.
AI_ENABLED=false
# Cheap, structured-output-capable Claude model for extraction. Any Claude model
# id works (e.g. claude-sonnet-4-6, claude-opus-4-8).
AI_MODEL_EXTRACT=claude-haiku-4-5
# Hard caps.
AI_MAX_OUTPUT_TOKENS=700
AI_DAILY_USD_CAP=2.00
# Log token usage + estimated cost to the ai_usage table.
AI_LOG_USAGE=true
